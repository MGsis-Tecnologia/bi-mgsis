# ─── Aplicação ────────────────────────────────────────────────
# Variáveis públicas (inlined no build do Next.js). Opcionais — têm defaults.
NEXT_PUBLIC_APP_NAME="Dash BI"
NEXT_PUBLIC_DEFAULT_CURRENCY="BRL"

# ─── Banco de dados (PostgreSQL / Prisma) ─────────────────────
# Connection string do seu Postgres. Se definida, o app pula a tela /setup
# e as tabelas são criadas automaticamente na primeira conexão.
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO?schema=public
DATABASE_URL="postgresql://usuario:senha@seu-host:5432/dashbi?schema=public"
